{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":preserveSemverRanges",
    "group:allNonMajor",
    "group:linters",
    "group:react"
  ],
  "packageRules": [
    {
      "groupName": "vite",
      "matchPackageNames": ["vite", "vitest", "/^@vitejs\\//", "/^@vitest\\//", "/vite-plugin-/"]
    }
  ]
}
